		<move>
			<model>
				<action animation="Units/AstraMilitarum/LordCommissarMove"
						sound="Units/AstraMilitarum/InfantryMove"
						soundCount="4"/>
			</model>
		</move>
		<throwGrenade weaponSlotName="FragGrenade" cooldown="10"
				requiredUpgrade="AstraMilitarum/FragGrenade">
			<model>
				<action animation="Units/AstraMilitarum/LordCommissarGrenade"
						beginFire="0.9"/>
			</model>				
		</throwGrenade>
		<throwGrenade weaponSlotName="KrakGrenade" cooldown="10"
				requiredUpgrade="AstraMilitarum/KrakGrenade">
			<model>
				<action animation="Units/AstraMilitarum/LordCommissarGrenade"
						beginFire="0.9"/>
			</model>
		</throwGrenade>
		<!-- Swarm  -->
		<auraOfDiscipline passive="1" rank="-1" rankMax="2" levelUpPriority="0.9"
			name="AstraMilitarum/uwu_ValhallanIceWarriors_Chenkov_Swarm"
			icon="Traits/UnendingHorde">
			<beginTargets>
				<selfTarget>
					<areas>
						<area affects="Tile" radiusMin="1" radiusMax="3">
							<modifiers>
								<modifier>
									<effects>
										<addTrait name="uwu_ValhallanIceWarriors_Chenkov_Swarm"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
						<!-- the tile one doesn't work when they die. this will work in the meantime, even though it only affects the ones who start the turn close to Chenkov -->
						<area affects="Unit" radiusMin="1" radiusMax="7">
							<modifiers>
								<modifier visible="0">
									<conditions>
										<unit>
											<allied/>
										</unit>
									</conditions>
									<effects>
										<addTrait duration="1" name="uwu_ValhallanIceWarriors_Chenkov_SwarmDeath"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
						<area affects="Unit">
							<modifiers>
								<modifier>
									<effects>
										<addTrait name="uwu_ValhallanIceWarriors_Chenkov_ActivateSwarm"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</auraOfDiscipline>
		<genericUnitAbility cooldown="5"
				useConditionsForVisiblity="1"
				name="AstraMilitarum/uwu_ValhallanIceWarriors_Chenkov_DeployGuardsman"
				icon="Units/AstraMilitarum/ValhallanGuardsman">
			<conditions>
				<unit>
					<trait name="uwu_ValhallanIceWarriors_Chenkov_ActivateSwarm"/>
				</unit>
			</conditions>
			<beginTargets>
				<target rangeMax="1">
					<conditions>
						<tile>
							<noUnit/>
							<land/>
							<noFeature name="GravityWaves"/>
						</tile>
					</conditions>
					<areas>
						<area affects="Tile">
							<modifiers>
								<modifier>
									<effects>
										<addUnit name="AstraMilitarum/ValhallanGuardsman"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</target>
			</beginTargets>
		</genericUnitAbility>
		<!-- Hold Them Down -->
		<auraOfDiscipline passive="1"  rank="-1" rankMax="2" levelUpPriority="0.6"
				name="AstraMilitarum/uwu_ValhallanIceWarriors_Chenkov_Stall"
				icon="Traits/HellstormTemplate"
				shoutString="Actions/BringItDown">
			<beginTargets>
				<selfTarget>
					<areas>
						<area affects="Tile" radiusMin="2" radiusMax="4">
							<modifiers>
								<modifier>
									<effects>
										<addTrait duration="1" name="uwu_ValhallanIceWarriors_Chenkov_Stall"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
						<area affects="Unit">
							<modifiers>
								<modifier>
									<effects>
										<addTrait name="uwu_ValhallanIceWarriors_Chenkov_ActivateStall"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</auraOfDiscipline>
		<!-- 	Strikes: Don't use with orbitalBarrage -->
		<!-- 		orbitalStrike has fx and works, but sometimes has unit take no damage -->
		<!-- 		skyOfFallingStars forces one target and uses the second actual weapon -->
		<!-- 		genericUnitAbility works, but sometimes has unit take no damage and has no FX -->
		<!-- 	Targetting Tile doesn't apply damage -->
		<!--	allied doesn't always work. affiliate doesn't change anything -->
		<!--    Does not damage units adjacent to Chenkov; worked around by only being 3 range-->
		<orbitalStrike cooldown="5"
				useConditionsForVisiblity="1"
				name="AstraMilitarum/uwu_ValhallanIceWarriors_Chenkov_StallBarrage"
				icon="Weapons/EarthshakerCannon">
			<model>
				<action sound="Weapons/EarthshakerCannon"
						soundCount="3"/>
			</model>
			<conditions>
				<unit>
					<trait name="uwu_ValhallanIceWarriors_Chenkov_ActivateStall"/>
				</unit>
			</conditions>
			<beginTargets>
				<target rangeMin="3" rangeMax="5">
					<conditions>
						<unit>
							<allied/>
							<trait name="uwu_ValhallanIceWarriors_Chenkov_Stall"/>
						</unit>
					</conditions>
					<areas>
						<area affects="Unit" radius="1">
							<modifiers>
								<!-- Enemy damage comes first. If it kills the targetted ally, it stops the followup damage. -->
								<modifier>
									<conditions>
										<unit>
											<enemy/>
										</unit>
									</conditions>
									<effects>
										<weaponDamage weapon="EarthshakerCannon"/>
									</effects>
								</modifier>
								<modifier visible="0">
									<conditions>
										<unit>
											<enemy/>
										</unit>
									</conditions>
									<effects>
										<weaponDamage weapon="EarthshakerCannon"/>
									</effects>
								</modifier>
								<!-- Allied damage -->
								<!-- Player only -->
								<modifier visible="0">
									<conditions>
										<unit>
											<affiliate/>
										</unit>
										<player>
											<notAIControlled/>
										</player>
									</conditions>
									<effects>
										<weaponDamage weapon="EarthshakerCannon"/>
										<weaponDamage weapon="EarthshakerCannon"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</target>
			</beginTargets>
		</orbitalStrike>
		<!-- Summary Execution with Attacks -->
		<!-- Available by default but can be upgraded -->
		<summaryExecution cooldown="1" rank="0" rankMax="3" levelUpPriority="0.3"
				requiredActionPoints="0"
				consumedActionPoints="0"
				consumedMovement="0"
				name="AstraMilitarum/uwu_ValhallanIceWarriors_Chenkov_Execute"
				icon="Actions/SummaryExecution">
			<model>
				<action animation="Units/AstraMilitarum/LordCommissarAttack"
						beginFire="0.4"
						endFire="2.53"
						sound="Actions/Reload"/>
			</model>
			<beginTargets>
				<target rangeMax="1" rangeMin="1">
					<conditions>
						<unit>
							<allied/>
							<noTrait name="Fortification"/>
							<noTrait name="Vehicle"/>
						</unit>
					</conditions>
					<areas>
						<area affects="Unit">
							<modifiers>
								<modifier>
									<effects>
										<groupSize add="-3"/> <!-- because he's funny-->
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</target>
				<selfTarget>
					<areas>
						<area affects="Unit" radius="3">
							<modifiers>
								<modifier>
									<conditions>
										<unit>
											<allied/>
										</unit>
									</conditions>
									<effects>
										<morale add="6"/>
										<addTrait duration="1" name="uwu_ValhallanIceWarriors_Chenkov_Execute"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>			
		</summaryExecution>
		<!-- Elite: Deploy Sappers -->
		<genericUnitAbility cooldown="5" elite="1" rank="-1" rankMax="0" levelUpPriority="1"
				name="AstraMilitarum/uwu_ValhallanIceWarriors_Chenkov_DeployThunderWolves"
				icon="Units/AstraMilitarum/uwu_ValhallanIceWarriors_ThunderWolves">
			<beginTargets>
				<target rangeMax="1">
					<conditions>
						<tile>
							<noUnit/>
							<land/>
							<noFeature name="GravityWaves"/>
						</tile>
					</conditions>
					<areas>
						<area affects="Tile">
							<modifiers>
								<modifier>
									<effects>
										<addUnit name="AstraMilitarum/uwu_ValhallanIceWarriors_ThunderWolves"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</target>
			</beginTargets>
		</genericUnitAbility>
		<!-- Default: Iron Will -->
		<ironWill beginOnDisappear="1"
				cooldown="10"
				passive="1">
			<model>
				<action sound="Actions/MysticBuff"
						soundDelay="0.5"/>
			</model>
			<beginTargets>
				<selfTarget>
					<areas>
						<area affects="Unit">
							<modifiers>
								<modifier>
									<effects>
										<addTrait name="IronWill"/>
									</effects>
								</modifier>
							</modifiers>
							<modifiers>
								<modifier>
									<conditions>
										<unit>
											<destroyed/>
										</unit>
									</conditions>
									<effects>
										<hitpointsFactorFromMax add="1.0"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</ironWill>
		<!-- Default: GULAG -->
		<!-- Max rank. More generous hp allowance -->
		<genericUnitAbility cooldown="10"
				name="AstraMilitarum/Gulag">
			<model>
				<action animation="Units/AstraMilitarum/LordCommissarShout"
						bone="ChestBone"
						sound="Impacts/KineticConcrete" soundCount="5"/>
			</model>
			<modifiers>
				<modifier visible="1">
					<effects>
						<foodCost base="2.5"/>
					</effects>
				</modifier>
			</modifiers>
			<beginTargets>
				<target rangeMax="3">
					<conditions>
						<unit>
							<!-- Works on Friend and Foe -->
							<!-- Low HP -->
							<hitpointsFraction less="0.15"/> <!-- 15 from 10%-->
							<!-- Forbidden Units -->
							<noTrait name="Vehicle"/>
							<noTrait name="Fortification"/>
							<noTrait name="MonstrousCreature"/>
						</unit>
						<!-- Surrounded by Valhallans -->
						<unit match="Any">
							<unitsInRange count="2" range="1">
								<allied/>
								<trait name="AstraMilitarum/Valhallan"/>
							</unitsInRange>
							<!-- HoL Compat -->
							<unitsInRange count="2" range="1">
								<allied/>
								<trait name="AstraMilitarum/IceWarriors+"/>
							</unitsInRange>
							<unitsInRange count="1" range="1">
								<allied/>
								<trait name="AstraMilitarum/Goodpair+"/>
							</unitsInRange>
						</unit>
					</conditions>
					<areas>
						<area affects="Unit">
							<modifiers>
								<modifier>
									<effects>
										<!-- KILL IT but don't affect exp and morale -->
										<addTrait name="Suicider"/>
										<hitpointsFactorFromMax add="-1"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</target>
				<!-- Now that's how I'm getting paid -->
				<selfTarget>
					<areas>
						<area affects="Unit">
							<modifiers>
								<modifier>
									<effects>
										<addTrait name="AstraMilitarum/GulagGains" duration="1" rank="2"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</genericUnitAbility>
		<!-- URAAAAAAAAAA -->
		<genericUnitAbility	cooldown="10"
				requiredActionPoints="1"
				consumedActionPoints="0" consumedMovement="0"
				name="AstraMilitarum/Ura"
				shoutString="Actions/AstraMilitarum/Ura">
			<model>
				<action sound="Actions/ValhallanUra" soundCount="6"/>
			</model>
			<beginTargets>
				<selfTarget>
					<conditions>
						<!-- Not having the cooldown -->
						<!-- 4 Infantry allies, with some being Valhallanss -->
						<unit>
							<noTrait name="AstraMilitarum/UraCooldown"/>
							<unitsInRange count="4" range="3">
								<allied/>
								<noTrait name="Vehicle"/>
								<noTrait name="Fortification"/>
							</unitsInRange>
						</unit>
						<!-- 2 of my Valhallans OR 1 HoL Valhallan -->
						<unit match="Any">
							<unitsInRange count="2" range="3">
								<allied/>
								<trait name="AstraMilitarum/Valhallan"/>
								<noTrait name="Vehicle"/>
								<noTrait name="Fortification"/>
							</unitsInRange>
							<!-- Versions for HoL -->
							<!--   Jurgen's Ice Warrior Trait. The one is covered by Good Pair so I'll leave this as 2 in case Devian adds more Ice Warriors -->
							<unitsInRange count="2" range="3">
								<allied/>
								<trait name="AstraMilitarum/IceWarrior+"/>
								<noTrait name="Vehicle"/>
								<noTrait name="Fortification"/>
							</unitsInRange>
							<!--  Cain and Jurgen's shared trait -->
							<unitsInRange count="1" range="3">
								<allied/>
								<trait name="AstraMilitarum/Goodpair+"/>
								<noTrait name="Vehicle"/>
								<noTrait name="Fortification"/>
							</unitsInRange>
						</unit>
					</conditions>
					<areas>
						<area affects="Unit" radius="3">
							<modifiers>
								<modifier>
									<conditions>
										<unit>
											<allied/>
											<noTrait name="AstraMilitarum/Ura"/>
											<noTrait name="AstraMilitarum/UraCooldown"/>
										</unit>
										<!-- Valhallans, including HoL -->
										<unit match="Any">
											<trait name="AstraMilitarum/Valhallan"/>
											<trait name="AstraMilitarum/IceWarrior+"/>
											<trait name="AstraMilitarum/Goodpair+"/>
										</unit>
									</conditions>
									<effects>
										<addTrait duration="2" name="AstraMilitarum/Ura"/>
										<addTrait duration="10" name="AstraMilitarum/UraCooldown"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</genericUnitAbility>
		<levelUp/>
		<shop/>
	</actions>
	<traits>
		<trait name="ExtraInfantryArmour" requiredUpgrade="AstraMilitarum/ExtraInfantryArmour"/>
		<trait name="Hero"/>
		<trait name="RefractorField"/>
		<trait name="Stubborn"/>
		
		<trait name="AstraMilitarum/Valhallan"/>
		<trait name="Unique"/>
	</traits>
	<!-- Too Many Voices compatibility -->
	<responses>
		<action name="BringItDown" sound="Units/AstraMilitarum/TooManyVoices/Heroes/Commissar_Ability_BringItDown" soundCount="1"/>
		<action name="SummaryExecution" sound="Units/AstraMilitarum/TooManyVoices/Heroes/Commissar_Ability_Execution" soundCount="1"/>
		<attack sound="Units/AstraMilitarum/TooManyVoices/Heroes/Commissar_Attack" soundCount="8"/>
		<move sound="Units/AstraMilitarum/TooManyVoices/Heroes/Commissar_Move" soundCount="8"/>
		<select sound="Units/AstraMilitarum/TooManyVoices/Heroes/Commissar_Select" soundCount="4"/>
		<productionCompleted sound="Units/AstraMilitarum/TooManyVoices/Heroes/Commissar_Complete" soundCount="1"/>
	</responses>
</unit>
