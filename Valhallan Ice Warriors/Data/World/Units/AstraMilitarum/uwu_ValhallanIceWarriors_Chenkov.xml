	<actions>
		<attack>
			<model>
				<action animation="Units/AstraMilitarum/LordCommissarAttack"
						beginFire="0.4"
						endFire="2.53"
						chargeAnimation="Units/AstraMilitarum/LordCommissarCharge"
						chargeBeginFire="0.25"
						chargeEndFire="1.1"
