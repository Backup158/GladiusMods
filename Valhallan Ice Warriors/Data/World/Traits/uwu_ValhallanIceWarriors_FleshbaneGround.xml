<?xml version="1.0" encoding="utf-8"?>
<trait alwaysVisible="1" category="Buff" visibilityCategory="Weapon">
	<modifiers>
		<modifier>
			<conditions>
				<encounter>
					<opponent>
						<!-- <noTrait name="Fortification"/> -->
						<noTrait name="Headquarters"/>
						<noTrait name="Vehicle"/>
					</opponent>
				</encounter>
			</conditions>
			<effects>
				<damage add="5"/>
			</effects>
		</modifier>
		<!-- Certain vehicles can have the damage boost -->
		<modifier visible="0">
			<conditions>
				<encounter>
					<opponent>
						<trait name="Vehicle"/>
					</opponent>
					<opponent match="Any">
						<trait name="OpenTopped"/>
						<trait name="Walker"/>
					</opponent>
				</encounter>
			</conditions>
			<effects>
				<damage add="5"/>
			</effects>
		</modifier>
		<!-- Other Vehicles -->
		<modifier>
			<conditions>
				<encounter>
					<opponent>
						<trait name="Vehicle"/>
						<noTrait name="OpenTopped"/>
						<noTrait name="Walker"/>
					</opponent>
				</encounter>
			</conditions>
			<effects>
				<damage add="3"/>
			</effects>
		</modifier>
		<!-- Cannot target air -->
		<modifier visible="0">
			<conditions>
				<encounter>
					<opponent match="Any">
						<trait name="Flyer"/>
						<trait name="Skimmer"/> <!-- Helicopters -->
					</opponent>
				</encounter>
			</conditions>
			<effects>
				<rangedAccuracy add="-999"/>
			</effects>
		</modifier>
		<!-- Less accurate against other flying types -->
		<modifier>
			<conditions>
				<encounter>
					<opponent match="Any">
						<trait name="JetPack"/>
						<trait name="Jetbike"/>
						<trait name="Necrons/ImmuneToNaturalLaw"/>
						<trait name="Necrons/Wraithflight"/>
						<trait name="Tyranids/BoundingLeap"/>
					</opponent>
				</encounter>
			</conditions>
			<effects>
				<rangedAccuracy mul="-0.5"/>
			</effects>
		</modifier>
	</modifiers>
	<onCombatOpponentModifiers>
		<modifier>
			<conditions>
				<encounter>
					<self>
						<attacking/>
					</self>
					<opponent>
						<noAttacking/>
						<!--
						<noTrait name="Fortification"/>
						<noTrait name="Vehicle"/>
						-->
					</opponent>
				</encounter>
			</conditions>
			<effects>
				<addTrait name="Concussion" duration="1"/>
			</effects>
		</modifier>
	</onCombatOpponentModifiers>
</trait>
