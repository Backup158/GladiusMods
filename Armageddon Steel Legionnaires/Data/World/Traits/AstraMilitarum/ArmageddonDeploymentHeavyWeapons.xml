<?xml version="1.0" encoding="utf-8"?>
<trait category="Buff" visible="1" icon="Traits/HeavyWeapon">
	<modifiers>
		<!-- If unit has moved, increase accuracy of heavy weapons -->
		<!-- Not intending to fully remove the debuff -->
		<modifier>
			<conditions>
				<unit>
					<movedThisTurn/>
				</unit>
				<weapon>
					<trait name="Heavy"/>
				</weapon>
			</conditions>
			<effects>
				<accuracy mul="0.33"/> <!-- 0.5 will cancel out the -0.5 from heavy trait, so adding 0.17 leaves it as -0.33 now -->
			</effects>
		</modifier>
		<!-- T6: Improved Frag Casings: Remove more -->
		<modifier requiredUpgrade="AstraMilitarum/BlastDamage">
			<conditions>
				<unit>
					<movedThisTurn/>
				</unit>
				<weapon>
					<trait name="Heavy"/>
				</weapon>
			</conditions>
			<effects>
				<accuracy mul="0.34"/> <!-- Debuff is now only -0.17 -->
			</effects>
		</modifier>
		<!-- T8: Hammer of Wrath: it will be fully removed. -->
		<modifier requiredUpgrade="AstraMilitarum/HammerOfWrath">
			<conditions>
				<unit>
					<movedThisTurn/>
				</unit>
				<weapon>
					<trait name="Heavy"/>
				</weapon>
			</conditions>
			<effects>
				<accuracy mul="0.33"/>
			</effects>
		</modifier>
	</modifiers>
</trait>