<?xml version="1.0" encoding="utf-8"?>
<trait category="Buff" visible="1" icon="Traits/Eldar/Crackshot">
	<onUnitDisembarked>
		<area affects="Unit">
			<modifiers>
                <!-- Doubled actions on disembark -->
				<modifier>
					<effects>
						<!-- permanent increase is wild -->
						<!--
						<actionPointsMax add="1"/>
						<actionPoints add="1"/>
						 -->
						<addTrait name="AstraMilitarum/uwu_SteelLegion_VeteranRefresh" duration="1"/>
					</effects>
				</modifier>
			</modifiers>
		</area>
	</onUnitDisembarked>
	<modifiers>
		<!-- Overwatch Soak -->
		<modifier>
			<conditions>
                <unit>
                    <notAttackedThisTurn/>
					<movedThisTurn/>
				</unit>
            </conditions>
			<effects>
				<rangedDamageReduction add="0.33"/>
			</effects>
		</modifier>
		<!-- No Escape -->
		<modifier>
			<effects>
				<rangedDamageReductionBypass add="0.33"/>
			</effects>
		</modifier>
		<!-- Alpha Strike -->
		<modifier>
			<conditions>
				<encounter>
					<opponent>
						<hitpointsFraction greater="0.5"/>
						<noAttacking/>
					</opponent>
				</encounter>
			</conditions>
			<effects>
				<damage mul="0.33"/>
			</effects>
		</modifier>
	</modifiers>
</trait>
