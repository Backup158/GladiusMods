<?xml version="1.0" encoding="utf-8"?>
<trait category="Buff" visible="1" icon="Units/AstraMilitarum/Chimera">
	<onUnitDisembarked>
		<area affects="Unit">
			<modifiers>
                <!-- Extra movement and damage on disembark -->
				<modifier>
					<effects>
						<addTrait name="Fleet" duration="2"/>
						<addTrait name="AstraMilitarum/ArmageddonDeploymentDamage" duration="1"/>
					</effects>
				</modifier>
				<!-- T3: Requires Awaken the Machine vehicle boost tech for disembark invul -->
				<modifier requiredUpgrade="AstraMilitarum/AwakenTheMachine">
					<effects>
						<addTrait name="AstraMilitarum/ArmageddonDeploymentDamageReduction" duration="1"/>
					</effects>	
				</modifier>
				<!-- T3 Medipack: Heal rate increase while inside. Done in another trait to avoid text bloat. -->
				<!-- T8 Hammer of Wrath tech: more attacks -->
				<modifier requiredUpgrade="AstraMilitarum/HammerOfWrath">
					<effects>
						<addTrait name="AstraMilitarum/ArmageddonDeploymentAttacks" duration="1"/>
					</effects>	
				</modifier>
			</modifiers>
		</area>
	</onUnitDisembarked>
</trait>
