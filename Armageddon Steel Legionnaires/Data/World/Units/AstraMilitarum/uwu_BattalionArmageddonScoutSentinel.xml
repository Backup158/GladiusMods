<?xml version="1.0" encoding="utf-8"?>
<unit>
	<model>
		<unit mesh="Units/AstraMilitarum/uwu_ArmageddonScoutSentinel"
				material="Units/AstraMilitarum/ScoutSentinel"
				idleAnimation="Units/AstraMilitarum/ScoutSentinelIdle"
				idleAnimationCount="2"
				normalWeight="0.1"
				scale="1.0 1.0 1.0"
				syncMovementSounds="1"
				explosionsBone="HullBone"
				walker="1"/>
	</model>
	<group size="4" rowSize="2" memberDeltaX="64" memberDeltaY="110"/>
	<weapons>
		<weapon name="Lascannon">
			<model>
				<beamWeapon muzzleBone=".MuzzleBone0"/>
			</model>
		</weapon>
		<weapon name="HunterKillerMissile" slotName="HunterKillerMissile"
				enabled="0">
			<model>
				<missileWeapon muzzleBone="MissileAttachment"/>
			</model>
		</weapon>
	</weapons>
	<modifiers>
		<modifier visible="0">
			<effects>
				<armor base="7"/> <!-- 6 | %armor base armor=10/10/10 -->
				<hitpointsMax base="20.0"/> <!-- 16 | %hitpointsMax base armor=10/10/10 wounds=2 -->
				<meleeAccuracy base="6"/> <!-- %meleeAccuracy base weaponSkill=3 -->
				<meleeAttacks base="1"/>
				<!-- <meleeInitiative base="3"/> -->
				<oreUpkeep base="6.0"/> <!-- 2, 6| %oreUpkeep base tier=6 factor=1 -->
				<oreCost base="120.0"/> <!-- 40, 120 but also Hydras and Chimeras are the same cost? lol | %oreCost base tier=6 factor=1 -->
				<moraleMax base="8"/> <!-- %moraleMax base leadership=7 -->
				<movementMax base="3"/>
				<productionCost base="54.0"/> <!-- 36, 54 | %productionCost base tier=6 factor=1 -->
				<rangedAccuracy base="6"/> <!-- %rangedAccuracy base ballisticSkill=3 -->
			</effects>
		</modifier>
	</modifiers>
	<strategyModifiers>
		<modifier>
			<effects>
				<increaseVehiclesScore base="1.0"/>
			</effects>
		</modifier>
	</strategyModifiers>
	<actions>
		<attack>
			<model>
				<action
						animation="Units/AstraMilitarum/ScoutSentinelAttack"
						beginFire="0.25" endFire="2.9"/>
			</model>				
		</attack>
		<die>
			<model>
				<action animation="Units/AstraMilitarum/ScoutSentinelDie"
						sound="Units/SmallVehicleDie"
						soundCount="3"
						soundDelay="0.45"/>
			</model>		
		</die>
		<idle>
			<model>
				<action animationSpeed="0.75"/>
			</model>
		</idle>
		<move>
			<model>
				<action animation="Units/AstraMilitarum/ScoutSentinelMove"
						sound="Units/AstraMilitarum/ScoutSentinelMove"
						soundCount="1"/>
			</model>				
		</move>
		<!-- From 3 cd -->
		<scout consumedActionPoints="0"
				consumedMovement="0"
				cooldown="5"
				requiredActionPoints="0">
			<model>
				<action sound="Actions/Scan"/>
			</model>
			<beginTargets>
				<selfTarget>
					<areas>
						<area affects="Tile" radius="3">
							<modifiers>
								<modifier>
									<effects>
										<reveal/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</scout>
		<createSmokeScreen
				icon="Traits/SmokeScreen"
				cooldown="10"
				requiredUpgrade="AstraMilitarum/SmokeLauncher">
			<model>
				<action sound="Actions/SmokeScreen"/>
			</model>
			<beginTargets>
				<selfTarget>
					<areas>
						<area affects="Tile">
							<modifiers>
								<modifier>
									<effects>
										<addFeature duration="3" name="SmokeScreen"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</createSmokeScreen>
		<hammerOfWrath consumedActionPoints="0" 
				consumedMovement="0"
				cooldown="3"
				requiredUpgrade="AstraMilitarum/HammerOfWrath">
			<model>
				<action sound="Actions/PsychicBuff"/>
			</model>
			<beginTargets>
				<selfTarget>
					<areas>
						<area affects="Unit">
							<modifiers>
								<modifier>
									<effects>
										<addTrait name="HammerOfWrath" duration="1"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</hammerOfWrath>
		<useWeapon weaponSlotName="HunterKillerMissile"
				cooldown="10"
				requiredUpgrade="AstraMilitarum/HunterKillerMissile">
			<model>
				<action beginFire="0.1" endFire="1.0"/>
			</model>
		</useWeapon>
	</actions>
	<traits>
		<trait name="CamoNetting" requiredUpgrade="AstraMilitarum/CamoNetting"/>
		<trait name="ExtraVehicleArmour" requiredUpgrade="AstraMilitarum/ExtraVehicleArmour"/>
		<trait name="RecoveryGear" requiredUpgrade="AstraMilitarum/RecoveryGear"/>
		<trait name="RelicPlating" requiredUpgrade="AstraMilitarum/RelicPlating"/>
		<trait name="MoveThroughCover"/>
		<!-- <trait name="OpenTopped"/> -->
		<trait name="TrainedSentinelPilots" requiredUpgrade="AstraMilitarum/TrainedSentinelPilots"/>
		<trait name="Vehicle"/>
		<trait name="Walker"/>
		<!-- Steel Legion -->
		<trait name="AstraMilitarum/SteelLegion"/>
		<trait name="AstraMilitarum/ArmageddonDeployment"/>
		<trait name="AstraMilitarum/ArmageddonDeploymentHealingRate" requiredUpgrade="AstraMilitarum/MediPack"/>
		<!-- Reinforcements -->
		<trait name="AstraMilitarum/StrengthInNumbers" requiredUpgrade="AstraMilitarum/StrengthInNumbers"/>
	</traits>
	<!-- Too Many Voices compatibility -->
	<responses>
		<action name="Scout" sound="Units/AstraMilitarum/TooManyVoices/Vehicles/Sentinel_Ability_Scout" soundCount="1"/>
		<action name="CreateSmokeScreen" sound="Units/AstraMilitarum/TooManyVoices/Vehicles/Sentinel_Ability_Smoke" soundCount="1"/>
		<attack sound="Units/AstraMilitarum/TooManyVoices/Vehicles/Sentinel_Attack" soundCount="8"/>
		<move sound="Units/AstraMilitarum/TooManyVoices/Vehicles/Sentinel_Move" soundCount="8"/>
		<select sound="Units/AstraMilitarum/TooManyVoices/Vehicles/Sentinel_Select" soundCount="4"/>
		<productionCompleted sound="Units/AstraMilitarum/TooManyVoices/Vehicles/Sentinel_Complete" soundCount="1"/>
	</responses>
</unit>
