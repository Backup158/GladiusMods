<?xml version="1.0" encoding="utf-8"?>
<unit>
	<model>
		<unit mesh="Units/AstraMilitarum/uwu_SteelLegion_Veteran"
				material="Units/AstraMilitarum/uwu_SteelLegion_Veteran"
				idleAnimation="Units/AstraMilitarum/GuardsmanIdle"
				idleAnimationCount="3"
				idleContinuously="1"
				normalWeight="0.1"
				scale="1 1 1"
				bloodBone="ChestBone"
				walker="1"/>
	</model>
	<group size="8" rowSize="4" memberDeltaX="70" memberDeltaY="50"/>
	<weapons>
		<weapon name="HotShotLasgun">
			<model>
				<beamWeapon mesh="Weapons/AstraMilitarum/SteelLegionLasgun"
						material="Weapons/AstraMilitarum/GuardsmanLasgun"
						bone="RightHandBone"
						muzzleBone="GuardsmanLasgunMuzzle0"
						fireInterval="0.3"/>
			</model>
		</weapon>
		<weapon name="uwu_SteelLegion_DisposableMissileKrak" slotName="DisposableMissileKrak" enabled="0">
			<model>
				<projectileWeapon mesh="Weapons/AstraMilitarum/SteelLegionLasgun"
						material="Weapons/AstraMilitarum/GuardsmanLasgun"
						bone="RightHandBone"
						muzzleBone="GuardsmanLasgunMuzzle0"/>
			</model>
		</weapon>
		<weapon name="uwu_SteelLegion_DisposableMissileFrag" slotName="DisposableMissileFrag" enabled="0">
			<model>
				<projectileWeapon mesh="Weapons/AstraMilitarum/SteelLegionLasgun"
						material="Weapons/AstraMilitarum/GuardsmanLasgun"
						bone="RightHandBone"
						muzzleBone="GuardsmanLasgunMuzzle0"/>
			</model>
		</weapon>
		<weapon name="uwu_SteelLegion_DisposableMissileFire" slotName="DisposableMissileFire" enabled="0">
			<model>
				<projectileWeapon mesh="Weapons/AstraMilitarum/SteelLegionLasgun"
						material="Weapons/AstraMilitarum/GuardsmanLasgun"
						bone="RightHandBone"
						muzzleBone="GuardsmanLasgunMuzzle0"/>
			</model>
		</weapon>
		<weapon name="FragGrenade" slotName="FragGrenade" enabled="0">
			<model>
				<grenadeWeapon muzzleBone="LeftHandBone"/>
			</model>
		</weapon>
		<weapon name="KrakGrenade" slotName="KrakGrenade" enabled="0">
			<model>
				<grenadeWeapon muzzleBone="LeftHandBone"/>
			</model>
		</weapon>
	</weapons>
	<modifiers>
		<modifier visible="0">
			<!-- Veterans are T8; Scions, T4 -->
			<!-- Making sure these stats are still human and less than Space Marines. Stats will be fudged with traits -->
			<effects>
				<armor base="6"/> <!-- %armor base armor=4+ |||| Scions base is 6-->
				<foodUpkeep base="2.0"/> <!-- %foodUpkeep base tier=6 factor=1 -->
				<foodCost base="50.0"/> <!-- 20 | %foodCost base tier=6 factor=0.5 -->
				<hitpointsMax base="2.0"/> <!-- %hitpointsMax base toughness=3 wounds=1 -->
				<meleeAccuracy base="6"/> <!-- %meleeAccuracy base weaponSkill=3 -->
				<meleeAttacks base="1"/>
				<oreCost base="50.0"/> <!-- 20 | %oreCost base tier=6 factor=0.5 -->
				<strengthDamage base="1"/> <!-- %strengthDamage base strength=3 -->
				<moraleMax base="6"/> <!-- %moraleMax base leadership=6 -->
				<movementMax base="3"/>
				<productionCost base="48.0"/> <!-- 36, Jannissaries are 42 | %productionCost base tier=6 factor=1 -->
				<rangedAccuracy base="8"/> <!-- %rangedAccuracy base ballisticSkill=4 -->
			</effects>
		</modifier>
	</modifiers>
	<strategyModifiers>
		<modifier>
			<effects>
				<increaseInfantryScore base="1.0"/>
			</effects>
		</modifier>
	</strategyModifiers>
	<actions>
		<attack>
			<model>
				<action animation="Units/AstraMilitarum/GuardsmanAttack"
						beginFire="0.35" endFire="2.5"/>
			</model>				
		</attack>
		<die>
			<model>
				<action animation="Units/AstraMilitarum/GuardsmanDie"
						animationCount="3"
						sound="Units/MediumUnarmoredDie"
						soundCount="4"
						soundDelay="0.4"
						voiceSound="Units/AstraMilitarum/InfantryDie"
						voiceSoundCount="5"/>
			</model>		
		</die>
		<idle>
			<model>
				<action/>
			</model>
		</idle>
		<move>
			<model>
				<action animation="Units/AstraMilitarum/GuardsmanMove"
						sound="Units/AstraMilitarum/InfantryMove"
						soundCount="4"/>
			</model>
		</move>
		<throwGrenade weaponSlotName="FragGrenade" cooldown="10"
				requiredUpgrade="AstraMilitarum/FragGrenade">
			<model>
				<action animation="Units/AstraMilitarum/GuardsmanGrenade"
						beginFire="0.833333333333"/>
			</model>
		</throwGrenade>
		<throwGrenade weaponSlotName="KrakGrenade" cooldown="10"
				requiredUpgrade="AstraMilitarum/KrakGrenade">
			<model>
				<action animation="Units/AstraMilitarum/GuardsmanGrenade"
						beginFire="0.833333333333"/>
			</model>				
		</throwGrenade>
		<mediPack cooldown="10" requiredUpgrade="AstraMilitarum/MediPack">
			<model>
				<action bone="ChestBone"
						sound="Actions/Heal"/>
			</model>
			<conditions>
				<unit>
					<damaged/>
				</unit>
			</conditions>
			<beginTargets>
				<selfTarget>
					<areas>
						<area affects="Unit">
							<modifiers>
								<modifier>
									<effects>
										<hitpointsFactorFromMax add="0.5"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</mediPack>
		<!-- Shoot Expendable Missiles -->
		<useWeapon cooldown="5"
				consumedActionPoints="1"
				weaponSlotName="DisposableMissileKrak"
				icon="Weapons/uwu_SteelLegion_DisposableMissileKrak">
			<model>
				<action	animation="Units/AstraMilitarum/GuardsmanAttack"
						beginFire="1.0" endFire="1.5"/>
			</model>
			<sharedCooldowns>
				<action name="UseWeapon/DisposableMissileFrag"/>
				<action name="UseWeapon/DisposableMissileFire"/>
			</sharedCooldowns>
		</useWeapon>
		<useWeapon cooldown="5"
				consumedActionPoints="1"
				weaponSlotName="DisposableMissileFrag"
				icon="Weapons/uwu_SteelLegion_DisposableMissileFrag">
			<model>
				<action	animation="Units/AstraMilitarum/GuardsmanAttack"
						beginFire="1.0" endFire="1.5"/>
			</model>
			<sharedCooldowns>
				<action name="UseWeapon/DisposableMissileKrak"/>
				<action name="UseWeapon/DisposableMissileFire"/>
			</sharedCooldowns>
		</useWeapon>
		<useWeapon cooldown="7"
				consumedActionPoints="1"
				weaponSlotName="DisposableMissileFire"
				icon="Weapons/uwu_SteelLegion_DisposableMissileFire">
			<model>
				<action	animation="Units/AstraMilitarum/GuardsmanAttack"
						beginFire="1.0" endFire="1.5"/>
			</model>
			<sharedCooldowns>
				<action name="UseWeapon/DisposableMissileKrak"/>
				<action name="UseWeapon/DisposableMissileFrag"/>
			</sharedCooldowns>
		</useWeapon>
		<!-- Refresh Action after disembark -->
		<genericUnitAbility consumedActionPoints="0"
				consumedMovement="0"
				name="AstraMilitarum/uwu_SteelLegion_VeteranRefreshAbility"
				icon="Actions/AstraMilitarumDefenseEdict"
				requiredActionPoints="0"
				cooldown="1">
			<model>
				<action sound="Actions/DrawSwordAndReload"/>
			</model>
			<conditions>
				<unit>
					<actionPoints equal="0"/>
				</unit>
				<unit match="Any">
					<hitpointsFraction less="0.5"/>
					<trait name="AstraMilitarum/uwu_SteelLegion_VeteranRefresh"/>
				</unit>
			</conditions>
			<beginTargets>
				<selfTarget>
					<areas>
						<area affects="Unit">
							<modifiers>
								<modifier>
									<effects>
										<actionPoints add="1"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</genericUnitAbility>
	</actions>
	<traits>
		<trait name="ExtraInfantryArmour" requiredUpgrade="AstraMilitarum/ExtraInfantryArmour"/>
		<trait name="MoveThroughCover"/>
		<trait name="VoxCaster" requiredUpgrade="AstraMilitarum/VoxCaster"/>
		<!-- Steel Legion -->
		<trait name="AstraMilitarum/SteelLegion"/>
		<trait name="AstraMilitarum/ArmageddonDeployment"/>
		<trait name="AstraMilitarum/ArmageddonDeploymentHealingRate" requiredUpgrade="AstraMilitarum/MediPack"/>
		<!-- Veteran specific -->
		<trait name="AstraMilitarum/uwu_SteelLegion_VeteranDeployment"/>
		<trait name="HitAndRun"/>
	</traits>
	<!-- Too Many Voices compatibility -->
	<responses>
		<action name="UseWeapon/FragGrenade" sound="Units/AstraMilitarum/TooManyVoices/Infantry/Tempestus_Attack" soundCount="8"/>
		<action name="UseWeapon/KrakGrenade" sound="Units/AstraMilitarum/TooManyVoices/Infantry/Tempestus_Attack" soundCount="8"/>
		<action name="MediPack" sound="Units/AstraMilitarum/TooManyVoices/Infantry/Tempestus_Ability_Med" soundCount="1"/>
		<action name="UseWeapon/DisposableMissileKrak" sound="Units/AstraMilitarum/TooManyVoices/Infantry/Tempestus_Attack" soundCount="8"/>
		<action name="UseWeapon/DisposableMissileFrag" sound="Units/AstraMilitarum/TooManyVoices/Infantry/Tempestus_Attack" soundCount="8"/>
		<action name="UseWeapon/DisposableMissileFire" sound="Units/AstraMilitarum/TooManyVoices/Infantry/Tempestus_Attack" soundCount="8"/>
		<attack sound="Units/AstraMilitarum/TooManyVoices/Infantry/Tempestus_Attack" soundCount="8"/>
		<move sound="Units/AstraMilitarum/TooManyVoices/Infantry/Tempestus_Move" soundCount="8"/>
		<select sound="Units/AstraMilitarum/TooManyVoices/Infantry/Tempestus_Select" soundCount="4"/>
		<productionCompleted sound="Units/AstraMilitarum/TooManyVoices/Infantry/Tempestus_Complete" soundCount="1"/>
	</responses>
</unit>
