<?xml version="1.0" encoding="utf-8"?>
<building>
	<actions>
		<!-- T2: Cult Mechanicus = Upgrades -->
		<produceUnit unit="AstraMilitarum/uwu_SemtexianBombardiers_Engineer" requiredUpgrade="AstraMilitarum/Upgrades"/>
		<!-- T3: Field Ordnance Battery, OR T5: Basilisk -->
		<produceUnit unit="AstraMilitarum/uwu_SemtexianBombardiers_Fusilier">
			<conditions>
				<player match="Any">
					<upgrade name="AstraMilitarum/FieldOrdnanceBattery"/>
					<upgrade name="AstraMilitarum/Basilisk"/>
				</player>
			</conditions>
		</produceUnit>
		<!-- T3: FOB -->
		<produceUnit unit="AstraMilitarum/uwu_SemtexianBombardiers_FieldOrdnanceBatter" requiredUpgrade="AstraMilitarum/FieldOrdnanceBattery"/>
	</actions>
</building>
