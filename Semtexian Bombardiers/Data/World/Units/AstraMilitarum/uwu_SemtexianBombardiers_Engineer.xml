<?xml version="1.0" encoding="utf-8"?>
<unit>
	<model>
		<unit mesh="Units/AstraMilitarum/Guardsman"
				material="Units/AstraMilitarum/Guardsman"
				idleAnimation="Units/AstraMilitarum/GuardsmanIdle"
				idleAnimationCount="3"
				idleContinuously="1"
				normalWeight="0.1"
				scale="1 1 1"
				bloodBone="ChestBone"
				walker="1"/>
	</model>
	<group size="6" rowSize="3" memberDeltaX="64" memberDeltaY="64"/>
	<weapons>
		<weapon name="Lasgun">
			<model>
				<beamWeapon mesh="Weapons/AstraMilitarum/GuardsmanLasgun"
						material="Weapons/AstraMilitarum/GuardsmanLasgun"
						bone="RightHandBone"
						muzzleBone="GuardsmanLasgunMuzzle0"
						fireInterval="0.3"/>
			</model>
		</weapon>
		<weapon name="uwu_SemtexianBombardiers_Pick" slotName="ServoArm" enabled="0">
			<model>
				<weapon fireInterval="1.0"/>
			</model>
		</weapon>
		<weapon name="FragGrenade" slotName="FragGrenade" enabled="0">
			<model>
				<grenadeWeapon muzzleBone="LeftHandBone"/>
			</model>		
		</weapon>
		<weapon name="KrakGrenade" slotName="KrakGrenade" enabled="0">
			<model>
				<grenadeWeapon muzzleBone="LeftHandBone"/>
			</model>		
		</weapon>
	</weapons>
	<modifiers>
		<modifier visible="0">
			<effects>
				<armor base="6"/> <!-- 8, Guardsmen are 4 | %armor base armor=3+ -->
				<oreUpkeep base="1.5"/> <!-- 1.5, 2 | %oreUpkeep base tier=5 factor=1 -->
				<energyCost base="10.0"/> <!-- 15, 0 | %energyCost base tier=5 factor=0.5 -->
				<hitpointsMax base="2.0"/> <!-- 2, 2 | %hitpointsMax base toughness=3 wounds=1 -->
				<meleeAccuracy base="6"/> <!-- %meleeAccuracy base weaponSkill=3 -->
				<meleeAttacks base="1"/>
				<strengthDamage base="1"/> <!-- %strengthDamage base strength=3 -->
				<!-- <meleeInitiative base="3"/> -->
				<moraleMax base="10"/> <!-- %moraleMax base leadership=8 -->
				<movementMax base="3"/>
				<foodCost base="5.0"/> <!-- 0, 10 -->
				<oreCost base="17.5"/> <!-- 15, 10 | %oreCost base tier=5 factor=0.5 -->
				<productionCost base="30.0"/> <!-- 30, 24 | %productionCost base tier=5 factor=1 -->
				<rangedAccuracy base="6"/> <!-- %rangedAccuracy base ballisticSkill=3 -->
			</effects>
		</modifier>
	</modifiers>
	<strategyModifiers>
		<modifier>
			<effects>
				<increaseSupportScore base="0.5"/>	
				<increaseInfantryScore base="1.0"/>		
			</effects>
		</modifier>
	</strategyModifiers>
	<actions>
		<attack>
			<model>
				<action animation="Units/AstraMilitarum/GuardsmanAttack"
						beginFire="0.35" endFire="2.5"/>
			</model>
		</attack>
		<die>
			<model>
				<action animation="Units/AstraMilitarum/GuardsmanDie"
						animationCount="3"
						sound="Units/MediumUnarmoredDie"
						soundCount="4"
						soundDelay="0.4"
						voiceSound="Units/AstraMilitarum/InfantryDie"
						voiceSoundCount="5"/>
			</model>
		</die>
		<idle>
			<model>
				<action animationSpeed="1.0"/>
			</model>
		</idle>
		<move>
			<model>
				<action animation="Units/AstraMilitarum/GuardsmanMove"
						sound="Units/AstraMilitarum/InfantryMove"
						soundCount="4"/>
			</model>
		</move>
		<clearTileUnitAbility cooldown="1"
				icon="Actions/ClearTile"
				name="ClearTile">
			<model>
				<action animation="Units/AstraMilitarum/GuardsmanGrenade"/>
			</model>
			<beginTargets>
				<target rangeMax="1">
					<conditions/>
					<areas/>
				</target>
			</beginTargets>
			<modifiers>
				<modifier visible="0">
					<effects>
						<influenceCost base="5"/>
						<oreCost base="5"/>
					</effects>
				</modifier>
			</modifiers>
		</clearTileUnitAbility>
		<useWeapon cooldown="1" weaponSlotName="ServoArm">
			<model>
				<action animation="Units/AstraMilitarum/GuardsmanGrenade"/>
			</model>	
		</useWeapon>
		<blessingsOfTheOmnissiah cooldown="1"
		name="uwu_SemtexianBombardiers_Engineer_Heal"
		icon="Actions/BlessingsOfTheOmnissiah">
			<model>
				<action animation="Units/AstraMilitarum/GuardsmanGrenade"
						sound="Actions/Heal"/>
			</model>
			<beginTargets>
				<target rangeMax="1">
					<conditions>
						<unit>
							<allied/>
							<damaged/>
						</unit>
						<unit match="Any">
							<!-- Only fortifications -->
							<trait name="Fortification"/>
							<!-- <trait name="Vehicle"/> -->
						</unit>
					</conditions>
					<areas>
						<area affects="Unit">
							<modifiers>
								<modifier>
									<effects>
										<!-- Weaker heal from 8 -->
										<hitpoints add="4"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</target>
			</beginTargets>
		</blessingsOfTheOmnissiah>
		<throwGrenade weaponSlotName="FragGrenade" cooldown="10"
				requiredUpgrade="AstraMilitarum/FragGrenade">
			<model>
				<action animation="Units/AstraMilitarum/GuardsmanGrenade"
						beginFire="0.833333333333"/>
			</model>				
		</throwGrenade>
		<throwGrenade weaponSlotName="KrakGrenade" cooldown="10"
				requiredUpgrade="AstraMilitarum/KrakGrenade">
			<model>
				<action animation="Units/AstraMilitarum/GuardsmanGrenade"
						beginFire="0.833333333333"/>
			</model>				
		</throwGrenade>
		<awakenTheMachine cooldown="5"
				requiredUpgrade="AstraMilitarum/AwakenTheMachine">
			<model>
				<action animation="Units/AstraMilitarum/GuardsmanGrenade"
						sound="Actions/MechanicalBuff"/>
			</model>
			<beginTargets>
				<target rangeMax="1">
					<conditions>
						<unit>
							<allied/>
							<noTrait name="PowerOfTheMachineSpirit"/>
						</unit>
						<unit match="Any">
							<trait name="Fortification"/>
							<trait name="Vehicle"/>
						</unit>
					</conditions>
					<areas>
						<area affects="Unit">
							<modifiers>
								<modifier>
									<effects>
										<!-- Less duration from 5  -->
										<addTrait duration="3" name="PowerOfTheMachineSpirit"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</target>
			</beginTargets>
		</awakenTheMachine>
		<constructImperialStrongpoint icon="Units/AstraMilitarum/ImperialStrongpoint"
				requiredUpgrade="AstraMilitarum/ImperialStrongpoint"
				cooldown="10">
			<model>
				<action animation="Units/AstraMilitarum/GuardsmanGrenade"
						sound="Actions/Construct"/>
			</model>
			<modifiers>
				<modifier visible="0">
					<effects>
						<!-- More Expensive from 40 -->
						<oreCost base="60"/>
					</effects>
				</modifier>
			</modifiers>
			<beginTargets>
				<target rangeMax="1">
					<conditions>
						<tile>
							<noFeatureCategory name="Resource"/>
							<noFeatureCategory name="WireWeed"/>
							<land/>
							<noEnemyCity/>
							<noUnit/>
							<noFeature name="GravityWaves"/>
						</tile>
					</conditions>
					<areas>
						<area affects="Tile">
							<modifiers>
								<modifier>
									<effects>
										<addUnit name="AstraMilitarum/ImperialStrongpoint"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</target>
			</beginTargets>
		</constructImperialStrongpoint>
		<constructVoidShieldGenerator icon="Units/AstraMilitarum/VoidShieldGenerator"
				requiredUpgrade="AstraMilitarum/VoidShieldGenerator"
				cooldown="10">
			<model>
				<action animation="Units/AstraMilitarum/GuardsmanGrenade"
						sound="Actions/Construct"/>
			</model>
			<modifiers>
				<modifier visible="0">
					<effects>
						<!-- more expensive from 20, 20 -->
						<energyCost base="30"/>
						<oreCost base="30"/>
					</effects>
				</modifier>
			</modifiers>
			<beginTargets>
				<target rangeMax="1">
					<conditions>
						<tile>
							<noFeatureCategory name="Resource"/>
							<noFeatureCategory name="WireWeed"/>
							<land/>
							<noEnemyCity/>
							<noUnit/>
							<noFeature name="GravityWaves"/>
						</tile>
					</conditions>
					<areas>
						<area affects="Tile">
							<modifiers>
								<modifier>
									<effects>
										<addUnit name="AstraMilitarum/VoidShieldGenerator"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</target>
			</beginTargets>
		</constructVoidShieldGenerator>
	</actions>
	<traits>
		<trait name="ExtraInfantryArmour" requiredUpgrade="AstraMilitarum/ExtraInfantryArmour"/>
		<trait name="VoxCaster" requiredUpgrade="AstraMilitarum/VoxCaster"/>
		<!-- Semtexian Bombardiers -->
		<trait name="AstraMilitarum/uwu_SemtexianBombardiers_Semtexian"/>
	</traits>
	<!-- Too Many Voices Integration -->
	<responses>
		<action name="UseWeapon/FragGrenade" sound="Units/AstraMilitarum/TooManyVoices/Infantry/Guardsman_Attack" soundCount="8"/>
		<action name="UseWeapon/KrakGrenade" sound="Units/AstraMilitarum/TooManyVoices/Infantry/Guardsman_Attack" soundCount="8"/>
		<action name="MediPack" sound="Units/AstraMilitarum/TooManyVoices/Infantry/Guardsman_Ability_Med" soundCount="1"/>
		<attack sound="Units/AstraMilitarum/TooManyVoices/Infantry/Guardsman_Attack" soundCount="8"/>
		<move sound="Units/AstraMilitarum/TooManyVoices/Infantry/Guardsman_Move" soundCount="8"/>
		<select sound="Units/AstraMilitarum/TooManyVoices/Infantry/Guardsman_Select" soundCount="4"/>
		<productionCompleted sound="Units/AstraMilitarum/TooManyVoices/Infantry/Guardsman_Complete" soundCount="1"/>
	</responses>
</unit>
