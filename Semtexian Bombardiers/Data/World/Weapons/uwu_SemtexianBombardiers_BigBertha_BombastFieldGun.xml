<?xml version="1.0" encoding="utf-8"?>
<weapon icon="Weapons/DestroyerMissile">
	<model>
		<projectileWeapon fireSound="Weapons/BombastFieldGun"
				fireSoundCount="3"/>
	</model>
	<modifiers>
		<modifier>
			<!-- Remember, Deathstrike is A=1, AP 8, DMG 12, and ignores cover with apocalyptic blast -->
			<!-- Cities have 6 armor. 4 AP +2 from Ordnance is fair -->
			<effects>
				<attacks add="3"/>
				<rangedArmorPenetration add="4"/> <!-- 4 | %rangedArmorPenetration add armorPiercing=-2 -->
				<rangedDamage add="10"/> <!-- 4 | %rangedDamage add strength=7 -->
				<strengthDamage base="0"/>
			</effects>
		</modifier>
	</modifiers>
	<target rangeMax="4" rangeMin="2"/>
	<traits>
		<trait name="Barrage"/>
		<trait name="LargeBlast"/>
		<trait name="HeavyWeapon"/>
		<trait name="AstraMilitarum/BlastDamage" requiredUpgrade="AstraMilitarum/BlastDamage"/>
		<!-- Big Bertha -->
		<trait name="Ordnance"/>
		<trait name="uwu_SemtexianBombardiers_Weapon_HighFire"/>
	</traits>
</weapon>