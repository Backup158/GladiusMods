	<!-- Infantry -->
	<!-- ============= -->
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_SwapFireMode" value="Raise Howitzer"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_SwapFireModeDescription" value="Switches the currently used weapon."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_SwapFireModeFlavor" value="According to the ancient designs, howitzers were designed to fulfil both the direct fire cannon role and the indirect fire mortar role, by allowing the barrel to dynamically raised and lowered. Imperial artillery teams continue this tradition by rubbing blessed oils and reciting the Litany of Verticality, soothing the machine spirit, before finally performing the sacred rite."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_SwapFireModeLower" value="Lower Howitzer"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_SwapFireModeLowerDescription" value="<string name='Actions/AstraMilitarum/uwu_SemtexianBombardiers_SwapFireModeDescription'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_SwapFireModeLowerFlavor" value="<string name='Actions/AstraMilitarum/uwu_SemtexianBombardiers_SwapFireModeFlavor'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_FireAntiTankMineShell" value="Fire Remote Anti-Tank Mine Servitor"/> <!-- Remote Anti-Armor Mine System (RAAMS) -->
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_FireAntiTankMineShellDescription" value="Deploys anti-tank mines on an empty tile."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_FireAntiTankMineShellFlavor" value="The Adeptus Mechanicus uncovered an STL for an ancient artillery shell. The shell contains anti-tank mines, held together until the shell explodes mid-air, scattering the mines. Naturally, these STLs already were designed to have calculations handled by servitors."/>
	<!-- Engineers -->
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_Engineer_Heal" value="Fortification Field Repairs"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_Engineer_HealDescription" value="Heals an adjacent damaged allied Fortification."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_Engineer_HealFlavor" value="While not as proficient as tech-priests of the Mechanicus, combat engineers have the knowledge to jury-rig repairs for their fortifications, hopefully buying enough time for reinforcements to swoop in."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_ConstructFlakTower" value="Construct <string name='Units/AstraMilitarum/uwu_SemtexianBombardiers_FlakTower'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_ConstructFlakTowerDescription" value="Cost of construction is reduced when done by Semtexians. <string name='Units/AstraMilitarum/uwu_SemtexianBombardiers_FlakTowerDescription'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_ConstructFlakTowerFlavor" value="<string name='Units/AstraMilitarum/uwu_SemtexianBombardiers_FlakTowerFlavor'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_ConstructHullDown" value="Construct <string name='Traits/uwu_SemtexianBombardiers_HullDown'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_ConstructHullDownDescription" value="Cost of construction is reduced when done by Semtexians. <string name='Traits/uwu_SemtexianBombardiers_HullDownDescription'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_ConstructHullDownFlavor" value="<string name='Traits/uwu_SemtexianBombardiers_HullDownFlavor'/>"/>
	<!-- ============= -->
	<!-- Vehicles -->
	<!-- ============= -->
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_FireSmokeShell" value="Fire Smoke Shell"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_FireSmokeShellDescription" value="Fires a smoke shell, creating a cloud of smoke on the targetted tile."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_FireSmokeShellFlavor" value="Sometimes, simply blowing things up isn't the answer. Sometimes, the most appropriate action is to cover the battlefield in smoke, allowing movement to go undetected. Whether your allies choose to close the gap or make it larger is up to them. Of course, the smoke goes both ways..."/>
	<!-- ============= -->
	<!-- Heroes -->
	<!-- ============= -->
	<!-- Big Bertha -->
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_Move" value="Dragged by Allies"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_MoveDescription" value="Nearby allies increase Big Bertha's movement by 2. Requires 1 adjacent vehicle or 3 adjacent infantry. The allies must have movement points available."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_MoveFlavor" value="&quot;Hook her up, and we'll move to the next firing position. Quickly boys, quickly! Or the commandant will get us faster than the counter-batteries!&quot;"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_Range" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_Range'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_RangeDescription" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_RangeDescription'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_RangeFlavor" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_RangeFlavor'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_Siege" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_Siege'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_SiegeDescription" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_SiegeDescription'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_SiegeFlavor" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_SiegeFlavor'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_Morale" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_Morale'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_MoraleDescription" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_MoraleDescription'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_MoraleFlavor" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_MoraleFlavor'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_Leader" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_Leader'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_LeaderDescription" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_LeaderDescription'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_LeaderFlavor" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_LeaderFlavor'/>"/>
	<!-- Basilisk Commander -->
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_ShakeThemAwake" value="Shake Them Awake"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_ShakeThemAwakeDescription" value="Fire the Earthshaker Cannon and gives the target Concussion and Slowed. Duration of Concussion is increased with levelup. At max rank, Concussion and Slowed are applied in a radius of 1."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_ShakeThemAwakeFlavor" value="Sentry duty is often marked by long spans of boredom. &quot;Exciting&quot; is certainly one way to describe artillery shells raining on your position, disrupting lines and troops. Before everyone can recover, enemy forces are already descending on their position."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_FlareShell" value="Fire Flare Shell"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_FlareShellDescription" value="Fire a flare, revealing tiles and reducing ranged damage reduction. Ranged damage reduction is further reduced upon levelup. At max level, reduce the cooldown."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_FlareShellFlavor" value="Under the cover of the night, the enemy won't see you until it's too late. With flares in the sky, everyone is exposed. Of course, troops quickly learn that this cuts both ways."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_DigIn" value="Dig In"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_DigInDescription" value="Adjacent troops gain <string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_DugIn'/>, and adjacent Semtexians are guarded. If possible, also construct <string name='Traits/uwu_SemtexianBombardiers_HullDown'/>s on the tiles temporarily."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_DigInFlavor" value="Artillery guns are typically best kept further behind allied lines, but that doesn't mean they need to be left undefended. Besides posting guards, small trenches can be dug to reduce their profiles. If the troops have time to rest, they have time to dig."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_FullBattery" value="Gunners, Full Batteries!"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_FullBatteryDescription" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_FullBatteryDescription'/> For allies within 1 tile, reload Hunter-Killer Missiles."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_FullBatteryFlavor" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_FullBatteryFlavor'/>"/>
	<!-- 	Copy for Manticore Commander -->
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_Manticore_FullBattery" value="Gunners, Full Batteries!"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_Manticore_FullBatteryDescription" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_FullBatteryDescription'/> For allies within 1 tile, reload Hunter-Killer Missiles and Manticore salvos."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_Manticore_FullBatteryFlavor" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_FullBatteryFlavor'/>"/>
	<!-- Deathstrike Commander -->
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_OrbitalBombardment" value="Orbital Bombardment"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_OrbitalBombardmentDescription" value="Operation that bombards the target enemy unit. This enemy is more vulnerable to the next attack. Upon levelup, cooldown is reduced, and damage is increased."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_OrbitalBombardmentFlavor" value="<string name='Actions/OrbitalStrikeFlavor'/> Upon levelup, cooldown is reduced. At max level, the radius is increased."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_OrbitalScan" value="Orbital Scan"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_OrbitalScanDescription" value="<string name='Actions/SciersGazeDescription'/> Target at the centre of the scan has reduced ranged damage reduction."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_OrbitalScanFlavor" value="Despite the warp storm raging above, there remain methods for observing enemy positions. Servo skulls slink about, transmitting precise positions to command. What will happen next? A massive payload of death rains from the skies? An armoured column cuts through the lines, delivering precise rounds upon key positions? Whatever it is, the enemy won't know until it's too late."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_Xenocide" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_Xenocide'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_XenocideDescription" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_XenocideDescription'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_XenocideFlavor" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_XenocideFlavor'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_LegalizeNuclearBombs" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_LegalizeNuclearBombs'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_LegalizeNuclearBombsDescription" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_LegalizeNuclearBombsDescription'/> At the cost of greatly reducing the morale of allies within 3 tiles."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_LegalizeNuclearBombsFlavor" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_LegalizeNuclearBombsFlavor'/>"/>
</language>
