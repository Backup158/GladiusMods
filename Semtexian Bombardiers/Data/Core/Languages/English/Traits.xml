	<!-- Heroes -->
	<!-- ============= -->
	<!-- Big Bertha -->
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha" value="Revealed Presence"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBerthaDescription" value="After attacking, this unit temporarily takes more damage."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBerthaFlavor" value="&quot;The bigger they are, the easier they are to target.&quot;"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_Range" value="Servo-Range-Finder"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_RangeDescription" value="Increases the range for Ordnance weapons. Accuracy decreases when firing beyond the previous maximum range."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_RangeFlavor" value="Servo-skulls fan the area, scanning for enemies. Upon contact, the soulless skulls transmit pict and locational data to Big Bertha's servitor calculator, which screams out angles for the crews to adjust fire to."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_Siege" value="Siege Until Victory"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_SiegeDescription" value="Increases damage against Fortifications, moreso if it is not a Headquarters."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_SiegeFlavor" value="&quot;Death was written large everywhere.&quot;"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_Morale" value="Break Their Walls; Break Their Spirits"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_MoraleDescription" value="Decreases morale of attacked enemy and adjacent enemies. Applies Concussion to the target; at max rank, apply Concussion to enemies adjacent to the target."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_MoraleFlavor" value="Facing superior numbers is a frightening prospect, but being behind formidable defences instills confidence. When those walls come crashing down, so does that confidence."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_Leader" value="Batteries, Follow My Lead!"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_LeaderDescription" value="Upon attacking an enemy, allies adjacent to Big Bertha gain ranged attacks. Upon killing an enemy Hero or Headquarters, gain Influence."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_LeaderFlavor" value="The night is quiet. The traitors stir in their trenches, twitching about and jostling their weapons in anticipation. Suddenly, a heretic Leman Russ Demolisher explodes into a ball of flames, followed by an flurry of Basilisk shells striking every square foot."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_LeaderActivate" value="are you ready boys"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_LeaderActivateDescription" value="*unzips your pants*"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_LeaderActivateFlavor" value="GRAPEFRUIT NOISES GRAPEFRUIT NOISES GRAPEFRUIT NOISES GR- =][= DATA EXPUNGED BY ORDERS OF THE EMPEROR'S HOLY INQUISITION =][="/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_LeaderFollower" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_Leader'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_LeaderFollowerDescription" value="Gains ranged attacks."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_LeaderFollowerFlavor" value="<string name='Traits/AstraMilitarum/uwu_SemtexianBombardiers_BigBertha_LeaderFlavor'/>"/>
	<!-- Basilisk Commander -->
	<entry name="uwu_SemtexianBombardiers_Illuminated" value="<string name='Traits/Illuminated'/>"/>
	<entry name="uwu_SemtexianBombardiers_IlluminatedDescription" value="<string name='Traits/IlluminatedDescription'/>"/>
	<entry name="uwu_SemtexianBombardiers_IlluminatedFlavor" value="<string name='Traits/IlluminatedFlavor'/>"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_DugIn" value="Dug In"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_DugInDescription" value="Reduced movement. If the unit has not moved, gain ranged damage reduction and accuracy with Barrage weapons."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_DugInFlavor" value="Staying in a dug-in position protects even artillery crews, giving extra breathing room to take aim and even absorbing recoil more efficiently. However, one must take care to have the flanks watched, for these crews are in no position to escape."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_FullBattery" value="Full Batteries!"/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_FullBatteryDescription" value="For barrage weapons, increases attacks and targets hit but decreases accuracy."/>
	<entry name="AstraMilitarum/uwu_SemtexianBombardiers_FullBatteryFlavor" value="One would hardly call artillery bombardments &quot;precise,&quot; but well-trained crews do actually aim their shots. However, there are times when precision must defer to sheer saturation. Sometimes, abominations need to die RIGHT NOW, accuracy be damned."/>
